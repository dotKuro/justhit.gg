---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, dateLocale, languages, defaultLang, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('reports');
  const bySlug = new Map<string, Partial<Record<Lang, CollectionEntry<'reports'>>>>();
  for (const entry of all) {
    const [loc, ...rest] = entry.id.split('/');
    const slug = rest.join('/');
    if (!bySlug.has(slug)) bySlug.set(slug, {});
    bySlug.get(slug)![loc as Lang] = entry;
  }

  const paths = [];
  for (const lang of Object.keys(languages) as Lang[]) {
    for (const [slug, locs] of bySlug) {
      const entry = locs[lang] ?? locs[defaultLang];
      if (!entry) continue;
      // isFallback: this locale has no translation, so we render the default one.
      paths.push({ params: { lang, slug }, props: { entry, isFallback: !locs[lang] } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const { entry, isFallback } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);

const dateLabel = entry.data.publishDate.toLocaleDateString(dateLocale[lang], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <article class="py-8">
    <a href={`/${lang}/`} class="text-sm text-muted transition-colors hover:text-fg">
      {t('report.back')}
    </a>

    {
      (entry.data.format ||
        entry.data.tier ||
        entry.data.placement ||
        entry.data.tags.length > 0) && (
        <div class="mt-6 flex flex-wrap gap-2">
          {[entry.data.format, entry.data.tier, entry.data.placement, ...entry.data.tags]
            .filter(Boolean)
            .map((badge) => (
              <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
                {badge}
              </span>
            ))}
        </div>
      )
    }

    <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
      {entry.data.title}
    </h1>
    <p class="mt-2 text-sm text-muted">
      {entry.data.event ? `${entry.data.event} · ${dateLabel}` : dateLabel}
    </p>

    {
      isFallback && (
        <p class="mt-4 rounded-lg border border-border bg-surface px-4 py-2 text-xs text-muted">
          {t('report.fallback')}
        </p>
      )
    }

    <div class="prose dark:prose-invert prose-report mt-8 max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
