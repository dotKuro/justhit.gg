---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PokemonIcon from '../../components/PokemonIcon.astro';
import { teamIconSpecies } from '../../lib/pokepaste';
import { localizedEntries } from '../../lib/content';
import { useTranslations, dateLocale, languages, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

type Card = {
  kind: 'report' | 'article';
  typeLabel: string;
  href: string;
  title: string;
  description: string;
  publishDate: Date;
  species: string[];
  tags: string[];
};

// Reports: resolve each headline team into icon species (build-time).
const reportCards: Card[] = await Promise.all(
  localizedEntries(await getCollection('reports'), lang).map(async ({ slug, entry }) => ({
    kind: 'report' as const,
    typeLabel: t('type.report'),
    href: `/${lang}/reports/${slug}/`,
    title: entry.data.title,
    description: entry.data.description,
    publishDate: entry.data.publishDate,
    species: entry.data.paste ? await teamIconSpecies(entry.data.paste) : [],
    tags: [entry.data.format, entry.data.tier, entry.data.placement, ...entry.data.tags].filter(
      Boolean,
    ) as string[],
  })),
);

// Articles: no team, just their own tags.
const articleCards: Card[] = localizedEntries(await getCollection('articles'), lang).map(
  ({ slug, entry }) => ({
    kind: 'article' as const,
    typeLabel: t('type.article'),
    href: `/${lang}/articles/${slug}/`,
    title: entry.data.title,
    description: entry.data.description,
    publishDate: entry.data.publishDate,
    species: [],
    tags: [...entry.data.tags],
  }),
);

// One combined feed, newest first.
const cards = [...reportCards, ...articleCards].sort(
  (a, b) => b.publishDate.valueOf() - a.publishDate.valueOf(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString(dateLocale[lang], { year: 'numeric', month: 'long', day: 'numeric' });

// Every chip on a card: the type label first (also a filter), then its tags.
const chipsOf = (c: Card) => [c.typeLabel, ...c.tags];
---

<BaseLayout lang={lang}>
  <p class="pt-6 text-sm text-muted">{t('site.tagline')}</p>

  <div class="mt-8 flex flex-wrap items-center gap-x-3 gap-y-2">
    <h1 class="text-2xl font-bold tracking-tight">{t('home.latest')}</h1>
    {/* Active filters render here (next to the heading), nudged to optical center. */}
    <div id="active-filters" class="relative top-[4px] flex flex-wrap items-center gap-2 text-[11px]"></div>
  </div>

  {
    cards.length === 0 ? (
      <p class="mt-4 text-muted">{t('home.empty')}</p>
    ) : (
      <>
        <ul id="report-list" class="mt-4 grid gap-4 pb-2">
          {cards.map((c) => (
            <li data-report data-tags={chipsOf(c).join('|')}>
              <div class="rounded-xl border border-border bg-surface transition-colors hover:border-accent">
                <a href={c.href} class="block px-6 pt-5">
                  {c.species.length > 0 && (
                    <div class="mb-3 flex flex-wrap gap-0.5">
                      {c.species.map((s) => (
                        <PokemonIcon species={s} />
                      ))}
                    </div>
                  )}
                  <p class="text-lg font-semibold">{c.title}</p>
                  <p class="mt-1 text-sm text-muted">{c.description}</p>
                  <p class="mt-3 text-xs text-muted/70">{fmtDate(c.publishDate)}</p>
                </a>
                <div class="flex flex-wrap gap-2 px-6 pb-5 pt-3 text-xs">
                  {/* Type chip: visually distinct (accent dot), but filters like any tag. */}
                  <button
                    type="button"
                    class="js-tag inline-flex cursor-pointer items-center gap-1 rounded-full border border-border px-2 py-0.5 font-semibold text-muted transition-colors hover:border-accent"
                    data-tag={c.typeLabel}
                    data-type-chip
                  >
                    <span class="js-dot relative top-[0.5px] size-1.5 rounded-full bg-accent" />
                    {c.typeLabel}
                  </button>
                  {c.tags.map((tag) => (
                    <button
                      type="button"
                      class="js-tag cursor-pointer rounded-full border border-border px-2 py-0.5 font-medium text-muted transition-colors hover:border-accent"
                      data-tag={tag}
                    >
                      {tag}
                    </button>
                  ))}
                </div>
              </div>
            </li>
          ))}
        </ul>
        <p id="no-match" hidden class="mt-4 pb-12 text-muted">
          {t('home.noMatch')}
        </p>
      </>
    )
  }
</BaseLayout>

<script>
  const filters = new Set<string>();
  const cards = [...document.querySelectorAll<HTMLElement>('[data-report]')];
  const tagButtons = [...document.querySelectorAll<HTMLButtonElement>('.js-tag')];
  const active = document.getElementById('active-filters');
  const noMatch = document.getElementById('no-match');

  // Tags rendered with a leading dot (the Report/Article type chips).
  const dotTags = new Set(
    [...document.querySelectorAll<HTMLElement>('[data-type-chip]')].map((b) => b.dataset.tag || ''),
  );

  const ACTIVE = ['border-accent', 'bg-accent', 'text-bg'];
  const INACTIVE = ['border-border', 'text-muted', 'hover:border-accent'];

  function paint(el: HTMLElement, on: boolean) {
    el.classList.toggle('cursor-pointer', true);
    if (on) {
      el.classList.add(...ACTIVE);
      el.classList.remove(...INACTIVE);
    } else {
      el.classList.add(...INACTIVE);
      el.classList.remove(...ACTIVE);
    }
    // Invert the dot to the background colour so it stays visible on the
    // accent-filled chip while selected.
    const dot = el.querySelector('.js-dot');
    if (dot) {
      dot.classList.toggle('bg-bg', on);
      dot.classList.toggle('bg-accent', !on);
    }
  }

  function update() {
    // Show a card only if it has every active tag (stacked = AND).
    let visible = 0;
    for (const card of cards) {
      const tags = (card.dataset.tags || '').split('|');
      const show = [...filters].every((f) => tags.includes(f));
      card.hidden = !show;
      if (show) visible++;
    }
    if (noMatch) noMatch.hidden = visible !== 0;

    // Highlight every matching tag button across the cards.
    for (const btn of tagButtons) paint(btn, filters.has(btn.dataset.tag || ''));

    // Render the active filters next to the heading.
    if (active) {
      active.replaceChildren();
      for (const f of filters) {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className =
          'inline-flex cursor-pointer items-center gap-1 rounded-full border border-accent bg-accent px-1.5 py-0.5 font-medium text-bg';
        // Mirror the type chips: a leading dot, inverted to the background colour.
        if (dotTags.has(f)) {
          const dot = document.createElement('span');
          dot.className = 'relative top-[0.5px] size-1.5 rounded-full bg-bg';
          chip.appendChild(dot);
        }
        chip.appendChild(document.createTextNode(`${f} ✕`));
        chip.addEventListener('click', () => toggle(f));
        active.appendChild(chip);
      }
    }

    syncUrl();
  }

  function toggle(tag: string) {
    if (filters.has(tag)) filters.delete(tag);
    else filters.add(tag);
    update();
  }

  // Reflect active filters in the URL (?tag=...), so a filtered view is
  // shareable and survives a reload.
  function syncUrl() {
    const url = new URL(window.location.href);
    url.searchParams.delete('tag');
    for (const f of filters) url.searchParams.append('tag', f);
    history.replaceState(null, '', url);
  }

  for (const btn of tagButtons) {
    btn.addEventListener('click', () => toggle(btn.dataset.tag || ''));
  }

  // Initialise from the URL on load. Unknown tags are kept too, so they show as
  // a removable chip and surface the "no posts match" state.
  for (const tag of new URL(window.location.href).searchParams.getAll('tag')) {
    if (tag) filters.add(tag);
  }
  update();
</script>
