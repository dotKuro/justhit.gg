---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TeamPreviewTool from '../../../components/TeamPreviewTool';
import { useTranslations, languages, type Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('team.tool.title')}>
  <h1 class="pt-8 text-2xl font-bold tracking-tight">{t('team.tool.title')}</h1>
  <p class="mt-2 text-sm text-muted">{t('team.tool.intro')}</p>

  <TeamPreviewTool client:load lang={lang} />
</BaseLayout>
