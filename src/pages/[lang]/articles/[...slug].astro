---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localizedEntries } from '../../../lib/content';
import { useTranslations, dateLocale, languages, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const paths = [];
  for (const lang of Object.keys(languages) as Lang[]) {
    for (const { slug, entry, isFallback } of localizedEntries(all, lang)) {
      paths.push({ params: { lang, slug }, props: { entry, isFallback } });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const { entry, isFallback } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);

const dateLabel = entry.data.publishDate.toLocaleDateString(dateLocale[lang], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <article class="py-8">
    <a href={`/${lang}/`} class="text-sm text-muted transition-colors hover:text-fg">
      {t('nav.back')}
    </a>

    {
      entry.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {entry.data.tags.map((badge) => (
            <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-muted">
              {badge}
            </span>
          ))}
        </div>
      )
    }

    <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
      {entry.data.title}
    </h1>
    <p class="mt-2 text-sm text-muted">{dateLabel}</p>

    {
      isFallback && (
        <p class="mt-4 rounded-lg border border-border bg-surface px-4 py-2 text-xs text-muted">
          {t('article.fallback')}
        </p>
      )
    }

    <div class="prose dark:prose-invert prose-report mt-8 max-w-none">
      <Content />
    </div>

    {
      entry.data.link && (
        <a
          href={entry.data.link}
          target="_blank"
          rel="noopener"
          class="mt-8 inline-flex items-center rounded-full border border-accent bg-accent px-4 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-90"
        >
          {entry.data.linkLabel ?? t('article.viewTool')}
        </a>
      )
    }
  </article>
</BaseLayout>
