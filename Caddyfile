# Plain HTTP file server — TLS is terminated upstream (Cloud Run / load balancer
# / reverse proxy). Binds to $PORT (Cloud Run injects it; defaults to 8080).
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip

	# Astro builds directory-style pages (…/index.html); file_server resolves
	# those and trailing-slash redirects automatically.
	file_server

	# Fingerprinted bundles are content-addressed (the hash changes when the
	# content does), so they can be cached forever.
	@fingerprinted path /_astro/*
	header @fingerprinted Cache-Control "public, max-age=31536000, immutable"

	# Sprites/items live at stable URLs, so they must stay revalidatable —
	# NOT immutable — or an updated sprite (or a bad deploy) gets stuck in
	# browser caches. One day, then revalidate.
	@sprites path /sprites/*
	header @sprites Cache-Control "public, max-age=86400"
}
