# Dependencies
node_modules/

# Build output
dist/
.astro/

# Raw sprite-pipeline input (5.7 GB — never commit; rebuilt via scripts/).
sprite-source/

# Animated Pokémon webps and Serebii item renders are hosted on the GCS
